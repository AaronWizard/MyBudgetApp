{
	"name": "My Budget App",
	"dockerComposeFile": "docker-compose.yml",
	"service": "app",
	"workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
	"features": {
		"ghcr.io/devcontainers/features/node:1": {}
	},
	"forwardPorts": [
		5000,
		4200,
		5432
	],
	"customizations": {
		"vscode": {
			"extensions": [
				"Angular.ng-template",
				"ms-dotnettools.csdevkit@2.10.3"
			]
		}
	}
}
